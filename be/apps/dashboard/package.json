    "@tailwindcss/postcss": "catalog:",
    "@tailwindcss/typography": "catalog:",
    "@tailwindcss/vite": "4.3.0",
    "@types/node": "25.8.0",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "10.5.0",
    "babel-plugin-react-compiler": "1.0.0",
    "code-inspector-plugin": "1.5.1",
    "eslint": "10.4.0",
