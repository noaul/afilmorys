# ============================
# Afilmory Docker 环境变量
# ============================

# --- 应用 ---
NODE_ENV=production
HOSTNAME=0.0.0.0
PORT=1841

# --- 应用端口 (宿主机映射) ---
# 格式: [绑定地址:]端口  例: 127.0.0.1:1841 只监听本地
APP_PORT=1841

# --- 数据库 (使用 1Panel 已有的 PostgreSQL) ---
# 格式: postgresql://用户名:密码@容器名:端口/数据库名
# 容器名: 运行 docker ps | grep postgres 查看
DATABASE_URL=postgresql://afilmory:你的数据库密码@1panel-postgresql:5432/afilmory

# --- Redis (使用 1Panel 已有的 Redis) ---
# 无密码: redis://容器名:6379/0
# 有密码: redis://:密码@容器名:6379/0
REDIS_URL=redis://:你的Redis密码@1panel-redis:6379/0

# --- 加密密钥 (必需！请更换为随机值) ---
# 生成方法: openssl rand -hex 32
CONFIG_ENCRYPTION_KEY=change_me_to_a_random_64_char_hex_string

# --- 认证密钥 (必需！请更换为随机值) ---
# 生成方法: openssl rand -hex 32
BETTER_AUTH_SECRET=change_me_to_a_random_64_char_hex_string

# --- 超级管理员 ---
# 允许登录的邮箱（逗号分隔多个）
AUTH_ALLOWED_EMAILS=your@email.com

# --- OAuth 社交登录 (可选) ---
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# --- 邮件服务 (可选) ---
# RESEND_API_KEY=
# RESEND_FROM=AFILMORY <notification@yourdomain.com>
