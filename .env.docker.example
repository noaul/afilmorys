# ============================
# Afilmory Docker 环境变量
# ============================

# --- 应用 ---
NODE_ENV=production
HOSTNAME=0.0.0.0
PORT=1841

# --- 应用端口 (宿主机映射) ---
APP_PORT=1841

# --- 数据库 ---
# 默认 docker-compose.yml 会启动内置 PostgreSQL，通常不用改
POSTGRES_USER=afilmory
POSTGRES_PASSWORD=change_me_to_a_strong_database_password
POSTGRES_DB=afilmory
DATABASE_URL=postgresql://afilmory:change_me_to_a_strong_database_password@db:5432/afilmory

# --- Redis ---
# 默认 docker-compose.yml 会启动内置 Redis，通常不用改
REDIS_URL=redis://redis:6379/0

# --- 加密/认证密钥 (必需！请更换为随机值) ---
# 生成方法: 在 VPS 上分别运行两次 openssl rand -hex 32
CONFIG_ENCRYPTION_KEY=change_me_to_a_random_64_char_hex_string
BETTER_AUTH_SECRET=change_me_to_another_random_64_char_hex_string

# --- 认证密钥 (必需！请更换为随机值) ---
# 生成方法: 在 VPS 上运行 openssl rand -hex 32
BETTER_AUTH_SECRET=change_me_to_a_random_64_char_hex_string

# --- 超级管理员 ---
# 允许登录的邮箱（逗号分隔多个）
AUTH_ALLOWED_EMAILS=your@email.com

# --- 登录白名单 (可选) ---
# 留空表示允许所有注册用户登录。多个邮箱用英文逗号分隔。
# AUTH_ALLOWED_EMAILS=owner@example.com,admin@example.com

# --- OAuth 社交登录 (可选) ---
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# --- 邮件服务 (可选) ---
# RESEND_API_KEY=
# RESEND_FROM=AFILMORY <notification@yourdomain.com>
