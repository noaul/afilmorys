{
  "name": "@afilmory/viewer-motion",
  "type": "module",
  "version": "0.0.5",
  "description": "Reusable motion primitives for fullscreen media viewers",
  "license": "MIT",
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*"
  },
  "main": "./src/index.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "test": "tsx --test src/*.test.ts",
    "type-check": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "dependencies": {
    "@use-gesture/react": "^10.3.1",
    "motion": "^12.38.0"
  },
  "devDependencies": {
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tsdown": "0.22.0"
  },
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "import": "./dist/index.mjs"
      },
      "./*": {
        "types": "./dist/*.d.mts",
        "import": "./dist/*.mjs"
      }
    }
  }
}
